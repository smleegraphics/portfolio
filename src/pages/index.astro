---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import LavaLampBackground from '../components/LavaLampBackground.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Sam Lee | Creative Developer & 3D Artist">
  <!-- Hero Section -->
  <section class="relative w-full min-h-screen bg-white dark:bg-gray-950">
    <!-- Lava lamp background - blobs that merge and flow -->
    <LavaLampBackground />

    <!-- Decorative blobs (absolute, full width) -->
    <div class="blob blob-purple w-72 h-72 -top-20 -right-20 opacity-20"></div>
    <div class="blob blob-pink w-64 h-64 top-40 -left-32 opacity-15" style="animation-delay: 2s;"></div>

    <!-- Centered content container -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 pt-12 pb-20 md:pt-16 md:pb-32 flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-16">

      <!-- Text Column -->
      <div class="max-w-2xl relative">
        <h1 class="text-4xl md:text-5xl lg:text-5xl font-display font-bold text-gray-900 dark:text-gray-100 leading-tight fade-in" style="animation-delay: 0.1s">
          Hi, I'm <span class="gradient-text">Sam Lee</span>
          <span class="inline-block animate-float" style="animation-delay: 0.5s;">✨</span>
        </h1>

        <p class="mt-2 text-3xl md:text-4xl lg:text-4xl font-display font-bold text-gray-400 dark:text-gray-500 fade-in" style="animation-delay: 0.15s">
          Technical Artist & Creative Engineer
        </p>

        <p class="mt-6 text-lg md:text-xl text-gray-600 dark:text-gray-400 fade-in" style="animation-delay: 0.2s">
          Crafting tools and experiences that bridge art and technology, with a passion for learning.
        </p>

        <div class="mt-8 flex flex-wrap gap-4 fade-in" style="animation-delay: 0.25s">
          <a href="/projects" class="btn-primary group">
            <span>View My Work</span>
            <svg class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/about" class="btn-secondary">
            Get to Know Me
          </a>
        </div>
      </div>

      <!-- Headshot Column -->
      <div class="flex-shrink-0 fade-in relative" style="animation-delay: 0.1s">
        <div id="headshot-container" class="relative w-[23rem] h-[30rem] md:w-[28rem] md:h-[34rem] lg:w-[30rem] lg:h-[39rem]">

          <!-- Soft glow behind -->
          <!-- <div class="absolute -inset-20 bg-gradient-to-br from-accent/20 via-purple-200/30 to-pink-200/20 blur-[80px] opacity-100"></div> -->

          <!-- Bean-shaped mask -->
          <div class="absolute left-0 right-0 bottom-0 h-[60%] overflow-hidden shadow-lg"
     style="border-radius: 75% 35% 65% 50% / 65% 70% 55% 50%; transform-origin: center;">

            <img
              src="/images/headshot.jpg"
              alt=""
              class="absolute left-0 w-full object-cover"
              style="height: 166.67%; top: -66.67%; object-position: 30% 20%;"
            />
          </div>

          <!-- Transparent overlay on top -->
          <img
            src="/images/headshot-transparent.png"
            alt="Sam Lee"
            class="absolute inset-0 w-full h-full object-cover drop-shadow-2xl z-10"
            style="object-position: 30% 20%;"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  {featuredProjects.length > 0 && (
    <section class="container pb-20">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-display font-bold text-gray-900 dark:text-gray-100">Featured Work</h2>
        <a href="/projects" class="link-fancy text-sm font-medium flex items-center gap-1 group">
          View all
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProjects.map((project, index) => (
          <div class="fade-in opacity-0" style={`animation-delay: ${0.1 + index * 0.1}s`}>
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              thumbnail={project.data.thumbnail}
              href={`/projects/${project.slug}`}
              tags={project.data.tags}
            />
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Quick Links -->
  <section class="container pb-20">
    <h2 class="text-2xl font-display font-bold text-gray-900 dark:text-gray-100 mb-8">Explore</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a
        href="/work-experience"
        class="group p-6 card-playful hover:border-accent/30"
      >
        <div class="w-14 h-14 bg-gradient-to-br from-blue-100 to-purple-200 rounded-2xl flex items-center justify-center mb-4 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3">
          <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="font-display font-semibold text-gray-900 dark:text-gray-100 group-hover:text-accent transition-colors">Work Experience</h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Professional work at Meta, Applied Intuition, and more.</p>
      </a>

      <a
        href="/projects"
        class="group p-6 card-playful hover:border-accent/30"
      >
        <div class="w-14 h-14 bg-gradient-to-br from-accent/20 to-purple-200 rounded-2xl flex items-center justify-center mb-4 transition-transform duration-300 group-hover:scale-110 group-hover:-rotate-3">
          <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
        </div>
        <h3 class="font-display font-semibold text-gray-900 dark:text-gray-100 group-hover:text-accent transition-colors">Projects</h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Personal projects, procedural tools, and creative experiments.</p>
      </a>

      <a
        href="/projects"
        class="group p-6 card-playful hover:border-accent/30"
      >
        <div class="w-14 h-14 bg-gradient-to-br from-pink-100 to-purple-200 rounded-2xl flex items-center justify-center mb-4 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3">
          <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="font-display font-semibold text-gray-900 dark:text-gray-100 group-hover:text-accent transition-colors">Art</h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">3D modeling, illustrations, concept art, and sketches.</p>
      </a>
    </div>
  </section>
</BaseLayout>
