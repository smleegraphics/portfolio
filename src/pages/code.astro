---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageGrid from '../components/ImageGrid.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', ({ data }) => {
  return data.tags?.includes('code') || data.tags?.includes('web');
});

const sortedProjects = projects.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Code Projects | Portfolio" description="Web applications, tools, and creative coding experiments.">
  <section class="container py-12 md:py-16">
    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Code Projects</h1>
      <p class="text-lg text-gray-600 max-w-2xl">
        A showcase of my development work, including web applications,
        tools, and creative coding experiments.
      </p>
    </header>

    <ImageGrid projects={sortedProjects} basePath="/projects" />
  </section>
</BaseLayout>
