---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageGrid from '../components/ImageGrid.astro';
import { getCollection } from 'astro:content';

// Get projects tagged with 'project' or 'personal'
const projects = await getCollection('projects', ({ data }) => {
  return data.tags?.includes('project') || data.tags?.includes('personal') || data.tags?.includes('code') || data.tags?.includes('web');
});

const sortedProjects = projects.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Projects | Sam Lee" description="Personal projects including procedural tools, creative experiments, and more.">
  <section class="container py-12 md:py-16">
    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">Projects</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl">
        A collection of personal projects, procedural tools, creative experiments,
        and fun builds I've worked on in my spare time.
      </p>
    </header>

    {sortedProjects.length > 0 ? (
      <ImageGrid projects={sortedProjects} basePath="/projects" />
    ) : (
      <div class="text-center py-12">
        <div class="w-20 h-20 bg-gradient-to-br from-accent/20 to-purple-200 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
        </div>
        <h2 class="text-xl font-display font-semibold text-gray-900 dark:text-gray-100 mb-2">Projects Coming Soon</h2>
        <p class="text-gray-600 dark:text-gray-400 max-w-md mx-auto">
          I'm currently adding my personal projects. Check back soon to see procedural tools,
          creative experiments, and more!
        </p>
      </div>
    )}
  </section>
</BaseLayout>
