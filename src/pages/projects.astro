---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageGrid from '../components/ImageGrid.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sketches = await getCollection('sketches');

const artProjects = allProjects
  .filter(p => p.data.tags?.includes('3d'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const technicalProjects = allProjects
  .filter(p => !p.data.tags?.includes('3d'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const traditionalArt = sketches
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Projects | Sam Lee" description="Technical tools, procedural systems, 3D art, and traditional art.">
  <section class="container py-12 md:py-16">
    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">Projects</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl">
        Personal projects spanning procedural tooling, 3D character and environment art, and traditional artwork.
      </p>
    </header>

    <!-- Technical & Tools -->
    <div class="mb-16">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-8">Technical & Tools</h2>
      <ImageGrid projects={technicalProjects} basePath="/projects" />
    </div>

    <!-- 3D Art -->
    <div class="mb-16">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-8">3D Art</h2>
      <ImageGrid projects={artProjects} basePath="/projects" />
    </div>

    <!-- Traditional Art -->
    <div>
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-8">Traditional Art</h2>
      <ImageGrid projects={traditionalArt} basePath="/sketches" />
    </div>
  </section>
</BaseLayout>
