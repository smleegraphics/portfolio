---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageGrid from '../components/ImageGrid.astro';
import { getCollection } from 'astro:content';

const sketches = await getCollection('sketches');

const sortedSketches = sketches.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Sketchbook | Portfolio" description="Traditional and digital sketches, concept art, and doodles.">
  <section class="container py-12 md:py-16">
    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Sketchbook</h1>
      <p class="text-lg text-gray-600 max-w-2xl">
        A collection of my sketches and drawings, from quick doodles to
        more polished concept art pieces.
      </p>
    </header>

    <ImageGrid projects={sortedSketches} basePath="/sketches" />
  </section>
</BaseLayout>
