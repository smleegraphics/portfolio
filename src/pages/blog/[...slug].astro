---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
};
---

<BaseLayout
  title={`${post.data.title} | Blog`}
  description={post.data.description}
  image={post.data.thumbnail}
>
  <article class="container py-12 md:py-16">
    <header class="max-w-3xl mx-auto mb-12">
      <a href="/blog" class="inline-flex items-center text-gray-500 hover:text-gray-700 mb-6 transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Blog
      </a>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{post.data.title}</h1>
      <div class="flex items-center gap-4 text-gray-500">
        <time>{formatDate(post.data.date)}</time>
        {post.data.tags && post.data.tags.length > 0 && (
          <>
            <span>&middot;</span>
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-xs rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          </>
        )}
      </div>
    </header>

    <div class="max-w-3xl mx-auto prose prose-lg prose-gray">
      <Content />
    </div>
  </article>
</BaseLayout>
