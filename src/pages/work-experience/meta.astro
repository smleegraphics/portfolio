---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Meta | Work Experience | Sam Lee" description="Technical Artist work at Meta.">
  <section class="container py-12 md:py-16">
    <header class="mb-12">
      <nav class="mb-6">
        <a href="/work-experience" class="inline-flex items-center text-sm text-gray-500 dark:text-gray-400 hover:text-accent transition-colors">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Work Experience
        </a>
      </nav>

      <div class="flex items-center gap-4 mb-6">
        <img src="/images/logos/meta-logo.png" alt="Meta logo" class="w-16 h-16 object-contain flex-shrink-0 rounded-2xl" />
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100">Meta</h1>
          <p class="text-gray-500 dark:text-gray-400">Technical Artist</p>
        </div>
      </div>

      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-3xl">
        Working on creative tools and experiences for the metaverse platform.
      </p>
    </header>

    <div class="prose prose-lg dark:prose-invert max-w-3xl">
      <h2>Overview</h2>
      <p>
        Add your Meta work experience content here. Describe the projects you worked on,
        the tools you developed, and the impact of your contributions.
      </p>

      <h2>Projects</h2>
      <p>
        Add details about specific projects, including images, videos, and descriptions
        of your role and contributions.
      </p>

      <h2>Technologies</h2>
      <ul>
        <li>Add relevant technologies</li>
        <li>Tools and frameworks used</li>
        <li>Skills developed</li>
      </ul>
    </div>
  </section>
</BaseLayout>
