---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Meta | Work Experience | Sam Lee" description="Technical Artist work at Meta.">
  <section class="container py-12 md:py-16">
    <header class="mb-12">
      <nav class="mb-6">
        <a href="/work-experience" class="inline-flex items-center text-sm text-gray-500 hover:text-accent transition-colors">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Work Experience
        </a>
      </nav>

      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center flex-shrink-0">
          <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.989C18.343 21.129 22 16.99 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
        </div>
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900">Meta</h1>
          <p class="text-gray-500">Technical Artist</p>
        </div>
      </div>

      <p class="text-lg text-gray-600 max-w-3xl">
        Working on creative tools and experiences for the metaverse platform.
      </p>
    </header>

    <div class="prose prose-lg max-w-3xl">
      <h2>Overview</h2>
      <p>
        Add your Meta work experience content here. Describe the projects you worked on,
        the tools you developed, and the impact of your contributions.
      </p>

      <h2>Projects</h2>
      <p>
        Add details about specific projects, including images, videos, and descriptions
        of your role and contributions.
      </p>

      <h2>Technologies</h2>
      <ul>
        <li>Add relevant technologies</li>
        <li>Tools and frameworks used</li>
        <li>Skills developed</li>
      </ul>
    </div>
  </section>
</BaseLayout>
