---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Applied Intuition | Work Experience | Sam Lee" description="Technical Artist work at Applied Intuition.">
  <!-- Password Gate -->
  <div id="password-gate" class="container py-12 md:py-16">
    <div class="max-w-md mx-auto text-center">
      <div class="w-20 h-20 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-2xl flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <h1 class="text-2xl font-display font-semibold text-gray-900 mb-2">Password Required</h1>
      <p class="text-gray-600 mb-8">This content is protected. Please enter the password to continue.</p>

      <form id="password-form" class="space-y-4">
        <input
          type="password"
          id="password-input"
          class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
          placeholder="Enter password"
          autocomplete="off"
        />
        <p id="password-error" class="hidden text-red-500 text-sm">Incorrect password. Please try again.</p>
        <button type="submit" class="w-full btn-primary">
          Unlock Content
        </button>
      </form>

      <a href="/work-experience" class="inline-flex items-center mt-6 text-sm text-gray-500 hover:text-accent transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Work Experience
      </a>
    </div>
  </div>

  <!-- Protected Content (hidden by default) -->
  <section id="protected-content" class="hidden container py-12 md:py-16">
    <header class="mb-12">
      <nav class="mb-6">
        <a href="/work-experience" class="inline-flex items-center text-sm text-gray-500 hover:text-accent transition-colors">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Work Experience
        </a>
      </nav>

      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-2xl flex items-center justify-center flex-shrink-0">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
          </svg>
        </div>
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900">Applied Intuition</h1>
          <p class="text-gray-500">Technical Artist</p>
        </div>
      </div>

      <p class="text-lg text-gray-600 max-w-3xl">
        Developing simulation and visualization tools for autonomous vehicle development.
      </p>
    </header>

    <div class="prose prose-lg max-w-3xl">
      <h2>Overview</h2>
      <p>
        Add your Applied Intuition work experience content here. Describe the projects you worked on,
        the tools you developed, and the impact of your contributions.
      </p>

      <h2>Projects</h2>
      <p>
        Add details about specific projects, including images, videos, and descriptions
        of your role and contributions.
      </p>

      <h2>Technologies</h2>
      <ul>
        <li>Add relevant technologies</li>
        <li>Tools and frameworks used</li>
        <li>Skills developed</li>
      </ul>
    </div>
  </section>

  <script is:inline>
    // Correct password (you can change this)
    const CORRECT_PASSWORD = 'letmein';

    function showContent() {
      document.getElementById('password-gate').classList.add('hidden');
      document.getElementById('protected-content').classList.remove('hidden');
      sessionStorage.setItem('ai_authenticated', 'true');
    }

    function checkPassword(password) {
      return password.toLowerCase().trim() === CORRECT_PASSWORD;
    }

    // Check if coming from work experience page with password
    const storedPassword = sessionStorage.getItem('ai_password');
    if (storedPassword && checkPassword(storedPassword)) {
      showContent();
      sessionStorage.removeItem('ai_password');
    }

    // Check if already authenticated
    if (sessionStorage.getItem('ai_authenticated') === 'true') {
      showContent();
    }

    // Handle form submission
    document.getElementById('password-form').addEventListener('submit', function(e) {
      e.preventDefault();
      const input = document.getElementById('password-input');
      const error = document.getElementById('password-error');

      if (checkPassword(input.value)) {
        showContent();
      } else {
        error.classList.remove('hidden');
        input.classList.add('border-red-300');
        input.value = '';
        input.focus();
      }
    });
  </script>
</BaseLayout>
