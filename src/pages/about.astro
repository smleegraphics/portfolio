---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Sam Lee Portfolio" description="Learn more about me, my background, and what I do.">
  <section class="container py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-8">About Me</h1>

      <!-- Headshot and intro -->
      <div class="flex flex-col md:flex-row gap-8 mb-12">
        <div class="flex-shrink-0">
          <img
            src="/images/headshot.jpg"
            alt="Sam Lee"
            class="w-48 h-48 rounded-full object-cover mx-auto md:mx-0"
          />
        </div>
        <div class="prose prose-lg">
          <p>
            Hi! I'm a creative developer and 3D artist passionate about building beautiful,
            functional digital experiences. I combine technical skills with artistic vision
            to create work that's both visually compelling and technically sound.
          </p>
        </div>
      </div>

      <div class="prose prose-lg">
        <h2>What I Do</h2>
        <ul>
          <li>
            <strong>Web Development</strong> - Building responsive, accessible websites
            and web applications using modern technologies like React, TypeScript, and Astro.
          </li>
          <li>
            <strong>3D Modeling</strong> - Creating characters, environments, and assets
            using Blender and other 3D tools.
          </li>
          <li>
            <strong>Visual Design</strong> - Designing user interfaces and creating
            illustrations and concept art.
          </li>
        </ul>

        <h2>Tools & Technologies</h2>
        <p>Here are some of the tools I work with regularly:</p>
        <ul>
          <li><strong>Development:</strong> TypeScript, React, Next.js, Astro, Node.js</li>
          <li><strong>3D:</strong> Blender, ZBrush, Substance Painter</li>
          <li><strong>Design:</strong> Figma, Adobe Creative Suite</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="bg-gray-50 py-16">
    <div class="container">
      <div class="max-w-xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Get in Touch</h2>
        <p class="text-gray-600 mb-8">
          I'm always interested in new opportunities and collaborations.
          Feel free to reach out!
        </p>

        <form
          action="https://formsubmit.co/smlee.graphics@gmail.com"
          method="POST"
          class="space-y-4 text-left"
        >
          <!-- Honeypot for spam prevention -->
          <input type="text" name="_honey" style="display:none">
          <!-- Disable captcha -->
          <input type="hidden" name="_captcha" value="false">
          <!-- Redirect back to site after submission -->
          <input type="hidden" name="_next" value="https://example.com/about?submitted=true">

          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition-shadow"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition-shadow"
              placeholder="your@email.com"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent outline-none transition-shadow resize-none"
              placeholder="Your message..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full btn-primary py-3"
          >
            Send Message
          </button>
        </form>

        <p class="mt-6 text-sm text-gray-500">
          Or email me directly at
          <a href="mailto:smlee.graphics@gmail.com" class="link">smlee.graphics@gmail.com</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
