---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Sam Lee" description="Technical Artist specializing in real-time graphics, procedural tools, and pipeline development.">
  <!-- Hero Section -->
  <section class="container py-12 md:py-20">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col lg:flex-row gap-12 items-center">
        <!-- Headshot -->
        <div class="flex-shrink-0 relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-accent/20 via-purple-200/30 to-pink-200/20 rounded-full blur-2xl"></div>
          <div class="relative w-56 h-56 md:w-64 md:h-64 rounded-full overflow-hidden shadow-xl">
            <img
              src="/images/about-me-headshot.JPG"
              alt="Sam Lee"
              class="w-full h-full object-cover scale-[1.35] -translate-y-[5%]"
            />
          </div>
        </div>

        <!-- Intro -->
        <div class="text-center lg:text-left">
          <h1 class="text-4xl md:text-5xl font-display font-bold text-gray-900 mb-6">
            <span class="gradient-text">About Me</span>
          </h1>
          <div class="space-y-4 text-gray-500 mb-8 max-w-xl">
            <p>
              Based in San Francisco, I specialize in real-time graphics, procedural tools, and pipeline development for games, VR/AR, and simulation.
            </p>
            <p>
              I was drawn to computer graphics through storytelling, creative expression, and the power of technology. In this rapidly evolving field, I'm excited to explore AI tooling and continue learning every day.
            </p>
            <p>
              In my spare time, I enjoy painting, playing board games, and improving my volleyball skills :)
            </p>
          </div>
          <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
            <a
              href="/Samantha_Lee_Resume.pdf"
              download
              class="btn-primary"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Download Resume
            </a>
            <a href="mailto:smlee.graphics@gmail.com" class="btn-secondary">
              Get in Touch
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What I Do -->
  <section class="py-12 bg-gradient-to-b from-white to-lavender-50/50">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-display font-bold text-gray-900 mb-6 text-center">What I Do</h2>

        <div class="space-y-4">
          <div class="flex gap-4">
            <div class="w-2 h-2 rounded-full bg-accent mt-2 flex-shrink-0"></div>
            <div>
              <span class="font-semibold text-gray-900">Real-Time Graphics & VR/AR</span>
              <span class="text-gray-600"> — Building immersive experiences and dynamic lighting systems for platforms like Meta Horizon.</span>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-2 h-2 rounded-full bg-accent mt-2 flex-shrink-0"></div>
            <div>
              <span class="font-semibold text-gray-900">Procedural Tools & Pipelines</span>
              <span class="text-gray-600"> — Developing custom Unreal Engine pipelines for asset processing, world generation, and content optimization.</span>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-2 h-2 rounded-full bg-accent mt-2 flex-shrink-0"></div>
            <div>
              <span class="font-semibold text-gray-900">Artist Tooling</span>
              <span class="text-gray-600"> — Shipping tools that increase efficiency and empower creative teams to do their best work.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Background -->
  <section class="py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-display font-bold text-gray-900 mb-10 text-center">Background</h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <!-- Education -->
          <div class="card-playful p-6">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 bg-gradient-to-br from-red-100 to-red-200 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-red-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path d="M12 14l9-5-9-5-9 5 9 5z" />
                  <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
                </svg>
              </div>
              <div>
                <h3 class="font-display font-semibold text-gray-900">University of Pennsylvania</h3>
                <p class="text-gray-500 text-sm">BSE Computer Science, Digital Media Design</p>
              </div>
            </div>
          </div>

          <!-- Experience Summary -->
          <div class="card-playful p-6">
            <h3 class="font-display font-semibold text-gray-900 mb-4">Experience</h3>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1.5 bg-blue-50 text-blue-700 rounded-full text-sm font-medium">Meta</span>
              <span class="px-3 py-1.5 bg-emerald-50 text-emerald-700 rounded-full text-sm font-medium">Applied Intuition</span>
              <span class="px-3 py-1.5 bg-purple-50 text-purple-700 rounded-full text-sm font-medium">ILMxLAB</span>
              <span class="px-3 py-1.5 bg-red-50 text-red-700 rounded-full text-sm font-medium">Marvel Studios</span>
              <span class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-full text-sm font-medium">Apple</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="py-16 bg-gradient-to-b from-lavender-50/50 to-white">
    <div class="container">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-display font-bold text-gray-900 mb-10 text-center">Skills & Tools</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Languages -->
          <div class="text-center">
            <h3 class="font-display font-semibold text-gray-900 mb-4">Languages</h3>
            <div class="flex flex-wrap justify-center gap-2">
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">C/C++</span>
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">Python</span>
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">HLSL</span>
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">OpenGL</span>
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">Blueprints</span>
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">JavaScript</span>
            </div>
          </div>

          <!-- Tools -->
          <div class="text-center">
            <h3 class="font-display font-semibold text-gray-900 mb-4">Tools</h3>
            <div class="flex flex-wrap justify-center gap-2">
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">Unreal Engine</span>
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">Houdini</span>
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">Maya</span>
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">Substance</span>
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">Photoshop</span>
            </div>
          </div>

          <!-- Workflow -->
          <div class="text-center">
            <h3 class="font-display font-semibold text-gray-900 mb-4">Workflow</h3>
            <div class="flex flex-wrap justify-center gap-2">
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">Git</span>
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">Perforce</span>
              <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 hover:border-accent/50 transition-colors">YAML</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
