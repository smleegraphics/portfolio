---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageGrid from '../../components/ImageGrid.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', ({ data }) => {
  return data.tags?.includes('3d');
});

const sortedProjects = projects.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="3D Art | Sam Lee" description="3D modeling projects including character designs, environments, and digital sculptures.">
  <section class="container py-12 md:py-16">
    <header class="mb-12">
      <nav class="mb-6">
        <a href="/art" class="inline-flex items-center text-sm text-gray-500 hover:text-accent transition-colors">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Art
        </a>
      </nav>

      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">3D Art</h1>
      <p class="text-lg text-gray-600 max-w-2xl">
        A collection of my 3D modeling work, including character designs, environments,
        and digital sculptures created in Blender and other tools.
      </p>
    </header>

    {sortedProjects.length > 0 ? (
      <ImageGrid projects={sortedProjects} basePath="/projects" />
    ) : (
      <div class="text-center py-12">
        <div class="w-20 h-20 bg-gradient-to-br from-accent/20 to-purple-200 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5" />
          </svg>
        </div>
        <h2 class="text-xl font-display font-semibold text-gray-900 mb-2">3D Art Coming Soon</h2>
        <p class="text-gray-600 max-w-md mx-auto">
          I'm currently adding my 3D artwork. Check back soon to see character designs,
          environments, and more!
        </p>
      </div>
    )}
  </section>
</BaseLayout>
