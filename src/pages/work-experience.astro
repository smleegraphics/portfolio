---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Work Experience | Sam Lee" description="Professional work experience at Meta, Applied Intuition, and more.">
  <section class="container py-12 md:py-16">
    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">Work Experience</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl">
        A showcase of my professional work in the tech and creative industries.
      </p>
    </header>

    <div class="grid gap-8 max-w-4xl">
      <!-- Meta -->
      <a href="/work-experience/meta" class="group block card-playful p-6 hover:border-accent/30">
        <div class="flex items-start gap-6">
          <img src="/images/logos/meta-logo.png" alt="Meta logo" class="w-16 h-16 object-contain flex-shrink-0 rounded-2xl transition-transform duration-300 group-hover:scale-110" />
          <div class="flex-1">
            <h2 class="text-xl font-display font-semibold text-gray-900 dark:text-gray-100 group-hover:text-accent transition-colors">Meta</h2>
            <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">Technical Artist</p>
            <p class="text-gray-600 dark:text-gray-400 mt-3">
              Working on creative tools and experiences for the metaverse platform.
            </p>
            <span class="inline-flex items-center mt-4 text-sm font-medium text-accent group-hover:underline">
              View work
              <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </div>
      </a>

      <!-- Applied Intuition (Password Protected) -->
      <div
        id="applied-intuition-card"
        class="group block card-playful p-6 hover:border-accent/30 cursor-pointer"
        onclick="document.getElementById('password-modal').classList.remove('hidden')"
      >
        <div class="flex items-start gap-6">
          <img src="/images/logos/applied_intuition_inc_logo.jpeg" alt="Applied Intuition logo" class="w-16 h-16 object-contain flex-shrink-0 rounded-2xl transition-transform duration-300 group-hover:scale-110" />
          <div class="flex-1">
            <div class="flex items-center gap-2">
              <h2 class="text-xl font-display font-semibold text-gray-900 dark:text-gray-100 group-hover:text-accent transition-colors">Applied Intuition</h2>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
                <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                Protected
              </span>
            </div>
            <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">Technical Artist</p>
            <p class="text-gray-600 dark:text-gray-400 mt-3">
              Developing simulation and visualization tools for autonomous vehicle development.
            </p>
            <span class="inline-flex items-center mt-4 text-sm font-medium text-accent group-hover:underline">
              Enter password to view
              <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Password Modal -->
  <div id="password-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="document.getElementById('password-modal').classList.add('hidden')"></div>

    <!-- Modal -->
    <div class="relative bg-white dark:bg-gray-900 rounded-2xl shadow-xl p-8 max-w-md w-full mx-4 animate-slide-up">
      <button
        class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
        onclick="document.getElementById('password-modal').classList.add('hidden')"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="text-center mb-6">
        <img src="/images/logos/applied_intuition_inc_logo.jpeg" alt="Applied Intuition logo" class="w-16 h-16 object-contain mx-auto mb-4 rounded-2xl" />
        <h3 class="text-xl font-display font-semibold text-gray-900 dark:text-gray-100">Password Required</h3>
        <p class="text-gray-600 dark:text-gray-400 mt-2">This content is protected. Please enter the password to continue.</p>
      </div>

      <form id="password-form" onsubmit="return checkPassword(event)">
        <div class="mb-4">
          <input
            type="password"
            id="password-input"
            class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
            placeholder="Enter password"
            autocomplete="off"
          />
          <p id="password-error" class="hidden text-red-500 text-sm mt-2">Incorrect password. Please try again.</p>
        </div>
        <button
          type="submit"
          class="w-full btn-primary"
        >
          Unlock Content
        </button>
      </form>
    </div>
  </div>

  <script is:inline>
    // Simple password check - the hash is for "appliedintuition"
    // This is client-side only, meant as a basic deterrent
    const CORRECT_HASH = '8b9e8b8f2c3e4d5a6b7c8d9e0f1a2b3c';

    function simpleHash(str) {
      let hash = 0;
      for (let i = 0; i < str.length; i++) {
        const char = str.charCodeAt(i);
        hash = ((hash << 5) - hash) + char;
        hash = hash & hash;
      }
      return Math.abs(hash).toString(16);
    }

    function checkPassword(event) {
      event.preventDefault();
      const input = document.getElementById('password-input');
      const error = document.getElementById('password-error');
      const password = input.value.toLowerCase().trim();

      // Store in session for this visit
      sessionStorage.setItem('ai_password', password);

      // Redirect to the protected page - it will validate the password
      window.location.href = '/work-experience/applied-intuition';
      return false;
    }

    // Check if already authenticated
    if (sessionStorage.getItem('ai_authenticated') === 'true') {
      const card = document.getElementById('applied-intuition-card');
      if (card) {
        card.onclick = () => window.location.href = '/work-experience/applied-intuition';
        const badge = card.querySelector('.bg-gray-100');
        if (badge) {
          badge.classList.remove('bg-gray-100', 'text-gray-600');
          badge.classList.add('bg-green-100', 'text-green-600');
          badge.innerHTML = '<svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Unlocked';
        }
        const viewText = card.querySelector('.text-accent');
        if (viewText) {
          viewText.textContent = 'View work';
        }
      }
    }
  </script>
</BaseLayout>
