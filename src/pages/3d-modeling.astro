---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageGrid from '../components/ImageGrid.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', ({ data }) => {
  return data.tags?.includes('3d');
});

const sortedProjects = projects.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="3D Modeling | Portfolio" description="3D modeling projects including character designs, environments, and digital sculptures.">
  <section class="container py-12 md:py-16">
    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">3D Modeling</h1>
      <p class="text-lg text-gray-600 max-w-2xl">
        A collection of my 3D modeling work, including character designs, environments,
        and digital sculptures created in Blender and other tools.
      </p>
    </header>

    <ImageGrid projects={sortedProjects} basePath="/projects" />
  </section>
</BaseLayout>
