---
import BaseLayout from './BaseLayout.astro';
import Lightbox from '../components/Lightbox.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  thumbnail: string;
  images?: string[];
  tags?: string[];
}

const { title, description, date, thumbnail, images = [], tags = [] } = Astro.props;
const allImages = [thumbnail, ...images];

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
}).format(date);
---

<BaseLayout title={`${title} | Portfolio`} description={description} image={thumbnail}>
  <article class="container py-12 md:py-16">
    <header class="mb-8">
      <a href="javascript:history.back()" class="inline-flex items-center text-gray-500 hover:text-gray-700 mb-4 transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back
      </a>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">{title}</h1>
      <p class="text-gray-600 mb-4">{formattedDate}</p>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-lg max-w-none mb-12">
      <slot />
    </div>

    {allImages.length > 0 && (
      <section class="mt-12">
        <h2 class="text-xl font-semibold mb-6">Gallery</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {allImages.map((img, index) => (
            <button
              class="lightbox-trigger aspect-[4/3] overflow-hidden rounded-lg cursor-pointer group"
              data-index={index}
            >
              <img
                src={img}
                alt={`${title} - Image ${index + 1}`}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
            </button>
          ))}
        </div>
      </section>
    )}
  </article>

  <Lightbox images={allImages} />
</BaseLayout>
