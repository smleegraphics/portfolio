---
interface Props {
  title: string;
  description: string;
  thumbnail: string;
  href: string;
  tags?: string[];
}

const { title, description, thumbnail, href, tags = [] } = Astro.props;
---

<a
  href={href}
  class="group block card-playful"
>
  <div class="aspect-[4/3] overflow-hidden relative">
    <img
      src={thumbnail}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      loading="lazy"
    />
    <!-- Subtle purple overlay on hover -->
    <div class="absolute inset-0 bg-gradient-to-t from-accent/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  </div>
  <div class="p-5">
    <h3 class="font-display font-semibold text-gray-900 dark:text-gray-100 group-hover:text-accent transition-colors duration-200">
      {title}
    </h3>
    <p class="mt-1.5 text-sm text-gray-600 dark:text-gray-400 line-clamp-2">{description}</p>
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((tag) => (
          <span class="px-2.5 py-1 bg-lavender-50 dark:bg-accent/10 text-accent-dark dark:text-accent-light text-xs font-medium rounded-full transition-colors duration-200 group-hover:bg-lavender-100 dark:group-hover:bg-accent/20">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
