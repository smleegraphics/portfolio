---
// LavaLampBackground.astro - Lava lamp metaball effect behind content
---

<div id="lava-lamp-container">
  <canvas id="lava-lamp-canvas"></canvas>
</div>

<style>
  #lava-lamp-container {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }
  #lava-lamp-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  function init() {
    const container = document.getElementById('lava-lamp-container');
    const canvas = document.getElementById('lava-lamp-canvas') as HTMLCanvasElement;

    if (!container || !canvas) return;

    const gl = canvas.getContext('webgl2') || canvas.getContext('webgl');
    if (!gl) {
      console.warn('WebGL not supported');
      return;
    }

    // Vertex shader - simple fullscreen quad
    const vertexShaderSource = `
      attribute vec2 a_position;
      varying vec2 v_uv;
      void main() {
        v_uv = a_position * 0.5 + 0.5;
        gl_Position = vec4(a_position, 0.0, 1.0);
      }
    `;

    // Fragment shader - metaball lava lamp effect
    const fragmentShaderSource = `
      precision highp float;
      varying vec2 v_uv;

      uniform float u_time;
      uniform vec2 u_resolution;
      uniform vec3 u_blob_positions[8];
      uniform float u_blob_radii[8];
      uniform vec3 u_colors[3];

      // Hash function for noise
      float hash(vec2 p) {
        return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);
      }

      // 2D noise
      float noise(vec2 p) {
        vec2 i = floor(p);
        vec2 f = fract(p);
        f = f * f * (3.0 - 2.0 * f); // smoothstep

        float a = hash(i);
        float b = hash(i + vec2(1.0, 0.0));
        float c = hash(i + vec2(0.0, 1.0));
        float d = hash(i + vec2(1.0, 1.0));

        return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
      }

      // Fractal noise for more organic look
      float fbm(vec2 p) {
        float value = 0.0;
        float amplitude = 0.3;
        for (int i = 0; i < 4; i++) {
          value += amplitude * noise(p);
          p *= 2.0;
          amplitude *= 0.5;
        }
        return value;
      }

      // Smooth metaball function
      float metaball(vec2 p, vec2 center, float radius) {
        float d = length(p - center);
        return radius * radius / (d * d + 0.0001);
      }

      void main() {
        vec2 uv = v_uv;
        vec2 aspect = vec2(u_resolution.x / u_resolution.y, 1.0);
        vec2 p = uv * aspect;

        // Add noise distortion for blobby edges
        vec2 distortion = vec2(
          fbm(p * 3.0 + vec2(u_time * 0.01, 0.0)),
          fbm(p * 3.0 + vec2(0.0, u_time * 0.012))
        );
        vec2 distortedP = p + (distortion - 0.5) * 0.2;

        // Calculate metaball field with distorted coordinates
        float field = 0.0;
        vec3 colorMix = vec3(0.0);
        float totalWeight = 0.0;

        for (int i = 0; i < 8; i++) {
          vec2 blobPos = u_blob_positions[i].xy * aspect;
          float contribution = metaball(distortedP, blobPos, u_blob_radii[i]);
          field += contribution;

          // Color mixing based on blob index
          int colorIndex = int(mod(float(i), 3.0));
          vec3 blobColor;
          if (colorIndex == 0) blobColor = u_colors[0];
          else if (colorIndex == 1) blobColor = u_colors[1];
          else blobColor = u_colors[2];

          colorMix += blobColor * contribution;
          totalWeight += contribution;
        }

        colorMix /= totalWeight + 0.0001;

        // Threshold for blob edges with soft falloff
        float threshold = 1.0;
        float edge = smoothstep(threshold - 0.3, threshold, field);

        // Add subtle gradient and glow
        vec3 finalColor = colorMix;
        finalColor += vec3(0.2, 0.05, 0.15) * (1.0 - edge) * 0.5;

        // Fade out near bottom of container
        float bottomFade = smoothstep(0.0, 0.15, v_uv.y);

        // Soft alpha for blending
        float alpha = edge * 0.60 * bottomFade;

        gl_FragColor = vec4(finalColor, alpha);
      }
    `;

    // Compile shader
    function compileShader(source: string, type: number): WebGLShader | null {
      const shader = gl.createShader(type);
      if (!shader) return null;
      gl.shaderSource(shader, source);
      gl.compileShader(shader);
      if (!gl.getShaderParameter(shader, gl.COMPILE_STATUS)) {
        console.error('Shader compile error:', gl.getShaderInfoLog(shader));
        gl.deleteShader(shader);
        return null;
      }
      return shader;
    }

    const vertexShader = compileShader(vertexShaderSource, gl.VERTEX_SHADER);
    const fragmentShader = compileShader(fragmentShaderSource, gl.FRAGMENT_SHADER);

    if (!vertexShader || !fragmentShader) return;

    // Create program
    const program = gl.createProgram();
    if (!program) return;
    gl.attachShader(program, vertexShader);
    gl.attachShader(program, fragmentShader);
    gl.linkProgram(program);

    if (!gl.getProgramParameter(program, gl.LINK_STATUS)) {
      console.error('Program link error:', gl.getProgramInfoLog(program));
      return;
    }

    gl.useProgram(program);

    // Create fullscreen quad
    const positions = new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]);
    const buffer = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buffer);
    gl.bufferData(gl.ARRAY_BUFFER, positions, gl.STATIC_DRAW);

    const positionLocation = gl.getAttribLocation(program, 'a_position');
    gl.enableVertexAttribArray(positionLocation);
    gl.vertexAttribPointer(positionLocation, 2, gl.FLOAT, false, 0, 0);

    // Get uniform locations
    const timeLocation = gl.getUniformLocation(program, 'u_time');
    const resolutionLocation = gl.getUniformLocation(program, 'u_resolution');
    const blobPositionsLocation = gl.getUniformLocation(program, 'u_blob_positions');
    const blobRadiiLocation = gl.getUniformLocation(program, 'u_blob_radii');
    const colorsLocation = gl.getUniformLocation(program, 'u_colors');

    // Purple color palette
    const colors = [
      139/255, 92/255, 246/255,   // #8b5cf6
      167/255, 139/255, 250/255,  // #a78bfa
      196/255, 181/255, 253/255,  // #c4b5fd
    ];
    gl.uniform3fv(colorsLocation, colors);

    // Blob configuration - positions and movement patterns
    const blobs = [
      { x: 0.3, y: 0.3, vx: 0.02, vy: 0.015, radius: 0.119, phase: 0 },
      { x: 0.8, y: 0.4, vx: -0.015, vy: 0.02, radius: 0.14, phase: 1 },
      { x: 0.5, y: 0.7, vx: 0.018, vy: -0.012, radius: 0.13, phase: 2 },
      { x: 0.3, y: 0.8, vx: -0.02, vy: -0.018, radius: 0.108, phase: 3 },
      { x: 0.7, y: 0.2, vx: 0.012, vy: 0.022, radius: 0.136, phase: 4 },
      { x: 0.15, y: 0.6, vx: -0.016, vy: 0.014, radius: 0.097, phase: 5 },
      { x: 0.85, y: 0.75, vx: 0.014, vy: -0.02, radius: 0.114, phase: 6 },
      { x: 0.5, y: 0.15, vx: -0.018, vy: 0.016, radius: 0.103, phase: 7 },
      { x: 0.0, y: 0.5, vx: 0, vy: 0, radius: 0.12, phase: 8 }
    ];

    // Enable blending
    gl.enable(gl.BLEND);
    gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);

    let isVisible = true;
    let animationId: number;

    function resize() {
      const dpr = Math.min(window.devicePixelRatio, 2);
      const width = container.clientWidth * dpr;
      const height = container.clientHeight * dpr;

      if (canvas.width !== width || canvas.height !== height) {
        canvas.width = width;
        canvas.height = height;
        gl.viewport(0, 0, width, height);
      }
    }

    function animate() {
      if (!isVisible) {
        animationId = requestAnimationFrame(animate);
        return;
      }

      resize();

      const time = performance.now() * 0.0001; // Very slow time

      // Update blob positions with slow, organic movement
      const positions: number[] = [];
      const radii: number[] = [];

      blobs.forEach((blob, i) => {
        // Slow sinusoidal movement
        const t = time + blob.phase * 0.5;
        const x = blob.x + Math.sin(t * blob.vx * 50) * 0.15 + Math.sin(t * 0.7 + i) * 0.1;
        const y = blob.y + Math.cos(t * blob.vy * 50) * 0.15 + Math.cos(t * 0.5 + i * 0.5) * 0.1;

        // Pulsing radius
        const r = blob.radius * (1 + Math.sin(t * 2 + blob.phase) * 0.2);

        positions.push(x, y, 0);
        radii.push(r);
      });

      gl.uniform1f(timeLocation, time);
      gl.uniform2f(resolutionLocation, canvas.width, canvas.height);
      gl.uniform3fv(blobPositionsLocation, positions);
      gl.uniform1fv(blobRadiiLocation, radii);

      gl.clear(gl.COLOR_BUFFER_BIT);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);

      animationId = requestAnimationFrame(animate);
    }

    animate();

    // Resize observer
    const resizeObserver = new ResizeObserver(() => resize());
    resizeObserver.observe(container);

    // Visibility observer
    const intersectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          isVisible = entry.isIntersecting;
        });
      },
      { threshold: 0.1 }
    );
    intersectionObserver.observe(container);

    // Cleanup
    document.addEventListener('astro:before-preparation', () => {
      cancelAnimationFrame(animationId);
      resizeObserver.disconnect();
      intersectionObserver.disconnect();
      gl.deleteProgram(program);
      gl.deleteShader(vertexShader);
      gl.deleteShader(fragmentShader);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('astro:page-load', init);
</script>
