---
import ProjectCard from './ProjectCard.astro';

interface Project {
  slug: string;
  data: {
    title: string;
    description: string;
    thumbnail: string;
    tags?: string[];
  };
}

interface Props {
  projects: Project[];
  basePath: string;
}

const { projects, basePath } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
  {projects.map((project) => (
    <div class="fade-in" style={`animation-delay: ${projects.indexOf(project) * 0.1}s`}>
      <ProjectCard
        title={project.data.title}
        description={project.data.description}
        thumbnail={project.data.thumbnail}
        href={`${basePath}/${project.slug}`}
        tags={project.data.tags}
      />
    </div>
  ))}
</div>

{projects.length === 0 && (
  <p class="text-center text-gray-500 dark:text-gray-400 py-12">No projects found.</p>
)}
